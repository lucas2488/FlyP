# ── Base de datos ──────────────────────────────────────────────────────────────
DB_USER=fly_user
DB_PASSWORD=cambia_esto_por_algo_seguro
DB_NAME=fly_db

# ── n8n ────────────────────────────────────────────────────────────────────────
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=cambia_esto_por_algo_seguro

# ── API Python ─────────────────────────────────────────────────────────────────
API_SECRET_KEY=genera_uno_con__openssl_rand_hex_32

# ── Dominios ───────────────────────────────────────────────────────────────────
N8N_DOMAIN=n8n.cordevs.com
API_DOMAIN=api.flypromociones.com

# ── SMTP (para emails desde n8n) ───────────────────────────────────────────────
# Opción A — Gmail con App Password (recomendado si ya usás Gmail)
#   1. Activar verificación en 2 pasos en la cuenta Google
#   2. Ir a myaccount.google.com/apppasswords → crear contraseña para "Mail"
#   3. Pegar esa contraseña de 16 caracteres en SMTP_PASS
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tu@gmail.com
SMTP_PASS=abcd_efgh_ijkl_mnop
SMTP_SENDER=FlyPromociones <tu@gmail.com>

# Opción B — Resend (servicio dedicado, free hasta 3000 emails/mes)
#   1. Registrarse en resend.com
#   2. API Keys → crear key
#   3. Usar los datos de abajo
# SMTP_HOST=smtp.resend.com
# SMTP_PORT=587
# SMTP_USER=resend
# SMTP_PASS=re_tu_api_key
# SMTP_SENDER=FlyPromociones <onboarding@resend.dev>

# ── Certbot ────────────────────────────────────────────────────────────────────
CERTBOT_EMAIL=tu@email.com
